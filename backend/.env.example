DATABASE_URL="file:./dev.db"
TELEGRAM_BOT_TOKEN="123456:ABC-DEF-your-bot-token"
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_JWT_SECRET="change-me-to-a-different-long-random-string"
PORT=3001
# Comma-separated when running the admin app on a separate dev port, e.g.:
# CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
CORS_ORIGIN="http://localhost:5173"
# Set to 1 to accept a fake initData payload signed with the string "test"
# instead of a real Telegram signature. Useful for local dev without a bot.
AUTH_DEV_MODE=0
